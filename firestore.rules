rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Entity validator for gallery items
    function isValidMediaItem(data) {
      return data.keys().hasAll(['id', 'type', 'url', 'alt', 'createdAt'])
          && data.keys().size() == 5
          && data.id is string && data.id.size() <= 200
          && (data.type == 'photo' || data.type == 'video')
          && data.url is string && data.url.size() <= 500
          && data.alt is string && data.alt.size() <= 200;
    }

    // Entity validator for profile config
    function isValidProfileConfig(data) {
      return data.keys().hasAll(['profileImage'])
          && data.keys().size() == 1
          && data.profileImage is string && data.profileImage.size() <= 500;
    }

    // Media collection matches
    match /media/{mediaId} {
      allow read: if true; // Public can see photos and videos
      allow create: if isSignedIn() && isValidId(mediaId) && isValidMediaItem(request.resource.data);
      allow update: if isSignedIn() && isValidId(mediaId) && isValidMediaItem(request.resource.data);
      allow delete: if isSignedIn() && isValidId(mediaId);
    }

    // Configurations collection matches
    match /configs/{configId} {
      allow read: if true; // Public can read configs (like profile image)
      allow write: if isSignedIn() && isValidId(configId) && isValidProfileConfig(request.resource.data);
    }
  }
}
